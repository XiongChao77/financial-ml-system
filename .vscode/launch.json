    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            // "args": ["-r","batch_experiments/2026-02-07/ETHUSDT_15m/10_45_43/reports.jsonl"],
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
        },
        {
            "name": "Batch Experiments: Resume DOGEUSDT_15m",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "args": ["-v"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}